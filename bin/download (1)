package com.tns.fooddeliverysystem.application;

import java.util.Scanner;

import com.tns.fooddeliverysystem.entities.*;
import com.tns.fooddeliverysystem.services.*;

public class FoodDeliverySystem {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        CustomerService customerService = new CustomerService();
        FoodService foodService = new FoodService();
        OrderService orderService = new OrderService();

        int choice;

        do {
            System.out.println("\n===== FOOD DELIVERY SYSTEM =====");
            System.out.println("1. Admin");
            System.out.println("2. Customer");
            System.out.println("3. Exit");
            System.out.print("Enter choice: ");
            choice = sc.nextInt();

            switch (choice) {

                // ================= ADMIN MENU =================
                case 1:
                    int adminChoice;
                    do {
                        System.out.println("\n--- ADMIN MENU ---");
                        System.out.println("1. Add Restaurant");
                        System.out.println("2. Add Food Item to Restaurant");
                        System.out.println("3. View Restaurants");
                        System.out.println("4. Add Delivery Person");
                        System.out.println("5. Back");
                        System.out.print("Enter choice: ");
                        adminChoice = sc.nextInt();

                        switch (adminChoice) {

                            case 1:
                                System.out.print("Enter Restaurant ID: ");
                                int rId = sc.nextInt();
                                sc.nextLine();
                                System.out.print("Enter Restaurant Name: ");
                                String rName = sc.nextLine();

                                Restaurant restaurant = new Restaurant(rId, rName);
                                foodService.addRestaurant(restaurant);
                                System.out.println("Restaurant Added!");
                                break;

                            case 2:
                                System.out.print("Enter Restaurant ID: ");
                                int restId = sc.nextInt();
                                System.out.print("Enter Food Item ID: ");
                                int fId = sc.nextInt();
                                sc.nextLine();
                                System.out.print("Enter Food Name: ");
                                String fName = sc.nextLine();
                                System.out.print("Enter Price: ");
                                double price = sc.nextDouble();

                                FoodItem foodItem = new FoodItem(fId, fName, price);
                                foodService.addFoodItemToRestaurant(restId, foodItem);
                                System.out.println("Food Item Added!");
                                break;

                            case 3:
                                System.out.println(foodService.getRestaurants());
                                break;

                            case 4:
                                System.out.print("Enter Delivery Person ID: ");
                                int dpId = sc.nextInt();
                                sc.nextLine();
                                System.out.print("Enter Name: ");
                                String dpName = sc.nextLine();
                                System.out.print("Enter Contact No: ");
                                long contact = sc.nextLong();

                                DeliveryPerson dp = new DeliveryPerson(dpId, dpName, contact);
                                orderService.addDeliveryPerson(dp);
                                System.out.println("Delivery Person Added!");
                                break;

                        }

                    } while (adminChoice != 5);
                    break;

                // ================= CUSTOMER MENU =================
                case 2:
                    int customerChoice;
                    Customer currentCustomer = null;

                    System.out.print("Enter Customer ID: ");
                    int cId = sc.nextInt();
                    sc.nextLine();
                    System.out.print("Enter Customer Name: ");
                    String cName = sc.nextLine();
                    System.out.print("Enter Contact No: ");
                    long cContact = sc.nextLong();

                    currentCustomer = new Customer(cId, cName, cContact);
                    customerService.addCustomer(currentCustomer);

                    do {
                        System.out.println("\n--- CUSTOMER MENU ---");
                        System.out.println("1. View All Food Items");
                        System.out.println("2. Add Item to Cart");
                        System.out.println("3. Place Order");
                        System.out.println("4. Back");
                        System.out.print("Enter choice: ");
                        customerChoice = sc.nextInt();

                        switch (customerChoice) {

                            case 1:
                                System.out.println(foodService.getAllFoodItems());
                                break;

                            case 2:
                                System.out.print("Enter Food Item ID: ");
                                int foodId = sc.nextInt();
                                System.out.print("Enter Quantity: ");
                                int qty = sc.nextInt();

                                for (FoodItem item : foodService.getAllFoodItems()) {
                                    if (item.getId() == foodId) {
                                        currentCustomer.addItem(item, qty);
                                    }
                                }
                                System.out.println("Added to Cart!");
                                break;

                            case 3:
                                Order order = new Order((int)(Math.random()*1000), currentCustomer);

                                currentCustomer.getCart().getItems().forEach(
                                        (item, quantity) -> order.addItem(item, quantity)
                                );

                                sc.nextLine();
                                System.out.print("Enter Delivery Address: ");
                                String address = sc.nextLine();
                                order.setDeliveryAddress(address);

                                orderService.placeOrder(order);

                                System.out.println("Order Placed Successfully!");
                                break;
                        }

                    } while (customerChoice != 4);
                    break;

            }

        } while (choice != 3);

        sc.close();
        System.out.println("Thank you for using Food Delivery System!");
    }
}